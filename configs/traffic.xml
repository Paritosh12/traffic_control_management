<?xml version='1.0' encoding='UTF-8'?>
<streamDB xmlns="http://sdms/stream" name="TrafficManagementDB">
    <stream>
        <name>sensor</name>
        <source>IoT_Sensors</source>
        <description>Stream of traffic sensor packets capturing vehicle count, speed, and occupancy.</description>
        <attributes>
            <timestampAttribute>
                <name>ts</name>
                <type>TIMESTAMP</type>
                <semanticRole>eventTime</semanticRole>
            </timestampAttribute>
            <attribute>
                <name>pkt_id</name>
                <type>VARCHAR(50)</type>
            </attribute>
            <attribute>
                <name>intersection_id</name>
                <type>VARCHAR(20)</type>
            </attribute>
            <attribute>
                <name>road_id</name>
                <type>VARCHAR(20)</type>
            </attribute>
            <attribute>
                <name>signal_id</name>
                <type>VARCHAR(30)</type>
            </attribute>
            <attribute>
                <name>vehicle_count</name>
                <type>INT</type>
            </attribute>
            <attribute>
                <name>avg_speed</name>
                <type>FLOAT</type>
                <unit>km/h</unit>
            </attribute>
            <attribute>
                <name>occupancy</name>
                <type>FLOAT</type>
                <unit>percentage</unit>
            </attribute>
        </attributes>
        <window>
            <windowType>Sliding</windowType>
            <size>5</size>
            <slideVelocity>10</slideVelocity>
            <unit>seconds</unit>
        </window>
    </stream>
    <stream>
        <name>event</name>
        <source>Emergency_Dispatch_Pedestrian_UI</source>
        <description>Stream of priority events like Emergency vehicles or Pedestrian crossings.</description>
        <attributes>
            <timestampAttribute>
                <name>ts</name>
                <type>TIMESTAMP</type>
                <semanticRole>eventTime</semanticRole>
            </timestampAttribute>
            <attribute>
                <name>event_id</name>
                <type>VARCHAR(50)</type>
            </attribute>
            <attribute>
                <name>event_type</name>
                <type>VARCHAR(20)</type>
            </attribute>
            <attribute>
                <name>intersection_id</name>
                <type>VARCHAR(20)</type>
            </attribute>
            <attribute>
                <name>road_id</name>
                <type>VARCHAR(20)</type>
            </attribute>
            <attribute>
                <name>priority</name>
                <type>INT</type>
            </attribute>
        </attributes>
        <window>
            <windowType>Tumbling</windowType>
            <size>10</size>
            <unit>events</unit>
        </window>
    </stream>
    <stream>
        <name>command</name>
        <source>Cloud_Traffic_Controller</source>
        <description>Stream of commands issued to traffic signals to change states.</description>
        <attributes>
            <timestampAttribute>
                <name>ts</name>
                <type>TIMESTAMP</type>
                <semanticRole>eventTime</semanticRole>
            </timestampAttribute>
            <attribute>
                <name>cmd_id</name>
                <type>VARCHAR(50)</type>
            </attribute>
            <attribute>
                <name>signal_id</name>
                <type>VARCHAR(30)</type>
            </attribute>
            <attribute>
                <name>action</name>
                <type>VARCHAR(10)</type>
            </attribute>
            <attribute>
                <name>duration</name>
                <type>INT</type>
                <unit>seconds</unit>
            </attribute>
            <attribute>
                <name>reason</name>
                <type>VARCHAR(20)</type>
            </attribute>
        </attributes>
        <window>
            <windowType>Landmark</windowType>
        </window>
    </stream>
</streamDB>